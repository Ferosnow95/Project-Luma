<Window x:Class="SlashCursor.Overlay.BubbleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Focusable="True">
    <!-- Full-screen, click-blocking layer. Transparent but hit-testable so
         clicks never reach the windows underneath while the bubble is open. -->
    <Grid x:Name="Root" Background="#01000000" MouseDown="Root_MouseDown">
        <Canvas x:Name="Layer">
            <!-- One-shot cursor trigger effects (ripple + sparkles) are spawned
                 here in code; never hit-testable so they don't block input. -->
            <Canvas x:Name="FxCanvas" IsHitTestVisible="False"/>

            <Border x:Name="Bubble"
                    Width="380"
                    MouseDown="Bubble_MouseDown"
                    CornerRadius="12"
                    Background="#FF1E1E1E"
                    BorderBrush="#FF3A3A3A"
                    BorderThickness="1"
                    Padding="14"
                    Opacity="0"
                    RenderTransformOrigin="0,0">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="BubbleScale" ScaleX="0.85" ScaleY="0.85"/>
                        <TranslateTransform x:Name="BubbleTranslate" X="0" Y="10"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Header: slash + provider + contextual title. -->
                    <DockPanel LastChildFill="True" Margin="0,0,0,10">
                        <TextBlock Text="/"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#FF7AA2F7"
                                   VerticalAlignment="Center"
                                   Margin="2,0,8,0"/>
                        <TextBlock x:Name="ProviderLabel"
                                   DockPanel.Dock="Right"
                                   Text="Mock"
                                   FontSize="11"
                                   Foreground="#FF888888"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="HeaderText"
                                   Text="What do you want to do?"
                                   FontSize="13"
                                   Foreground="#FFBBBBBB"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Step 1: choose an action pill (scroll / arrows / click). -->
                    <StackPanel x:Name="PillPanel">
                        <StackPanel x:Name="PillBar" Orientation="Horizontal"/>
                        <TextBlock x:Name="PillHint"
                                   Margin="2,10,0,0"
                                   Text="Scroll to choose  ·  Enter or click to select"
                                   FontSize="11"
                                   Foreground="#FF888888"/>
                    </StackPanel>

                    <!-- Step 2: ask a question about the selected context. -->
                    <StackPanel x:Name="AskPanel" Visibility="Collapsed">
                        <DockPanel LastChildFill="True">
                            <Border x:Name="ModeBadge"
                                    DockPanel.Dock="Left"
                                    Background="#FF2A3550"
                                    CornerRadius="6"
                                    Padding="8,3"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="ModeBadgeText"
                                           Text="Summarize"
                                           FontSize="12"
                                           Foreground="#FF9DB8FF"/>
                            </Border>
                            <TextBox x:Name="Input"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="White"
                                     CaretBrush="White"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     KeyDown="Input_KeyDown"/>
                        </DockPanel>

                        <TextBlock x:Name="Hint"
                                   Margin="0,8,0,0"
                                   Text="Type your question, Enter to ask  ·  Esc to close"
                                   FontSize="11"
                                   Foreground="#FF888888"/>

                        <Border x:Name="AnswerBox"
                                Visibility="Collapsed"
                                Margin="0,12,0,0"
                                Background="#FF252525"
                                BorderBrush="#FF3A3A3A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                MaxHeight="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="Answer"
                                           TextWrapping="Wrap"
                                           Foreground="#FFE0E0E0"
                                           FontSize="13"/>
                            </ScrollViewer>
                        </Border>

                        <!-- Web result cards (mocked for Search mode). -->
                        <ScrollViewer x:Name="ResultsScroll"
                                      Visibility="Collapsed"
                                      Margin="0,10,0,0"
                                      MaxHeight="260"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="Results"/>
                        </ScrollViewer>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
